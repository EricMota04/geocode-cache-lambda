{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "System.Net.Http.HttpClient": "Warning"
    }
  },
  "Cache": {
    "TtlDays": 30,
    "NegativeTtlDays": 1
  },
  "Google": {
    "BaseUrl": "https://maps.googleapis.com/maps/api/geocode/json",
    "TimeoutSeconds": 10,
    "MaxRetries": 3
  }
}

# Copy to terraform.tfvars and adjust. (terraform.tfvars is gitignored.)

aws_region   = "us-east-1"
project_name = "geocode-cache"
environment  = "dev"

# Path to the built Lambda zip (run `make package` or scripts/package-lambda.sh first).
lambda_package_path = "../../artifacts/GeocodeCache.Lambda.zip"

# Name of the Secrets Manager secret that will hold the Google API key.
google_api_key_secret_name = "geocode-cache/google-api-key"

cache_ttl_days    = 30
negative_ttl_days = 1

tags = {
  Owner = "eric"
}
